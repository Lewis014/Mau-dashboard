# Dashboard MAU — Variables de entorno
# Copia este archivo a .env y completa los valores

# PostgreSQL (mismos valores que el .env del stack contatech-aegis)
DB_HOST=postgres
DB_PORT=5432
DB_NAME=n8n
DB_USER=           # = POSTGRES_USER del stack n8n
DB_PASSWORD=       # = POSTGRES_PASSWORD del stack n8n

# Anthropic — para generación de briefs con Claude
ANTHROPIC_API_KEY=

# Token de acceso al dashboard (genera uno con: openssl rand -hex 32)
APP_TOKEN=
